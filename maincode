     02 — NEURO: RECEIVING
══════════════════════════════════════ -->
<section id="neuro-receive" class="system-section sec-neuro-r" style="background:var(--surface2)">
  <div class="sys-header">
    <div class="sys-step-tag">Step 02 · The Brain Decodes the Question</div>
    <h2 class="sys-title">Neurological System:<br/>Receiving &amp; Understanding</h2>
    <p class="sys-subtitle">The neural signal from CN VIII travels through a series of brainstem relay stations before reaching the cortex, where Wernicke's area decodes the linguistic meaning of "Do you like cheese?"</p>
  </div>

  <!-- Pathway strip -->
  <div class="pathway-strip" id="audi-pathway">
    <div class="pw-node active" onclick="setPW('audi-pathway',0,this)" style="--pc:var(--neuro-r)">
