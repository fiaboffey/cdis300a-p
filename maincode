<script>
// ── HOTSPOT POPUPS ──
document.querySelectorAll('.hotspot').forEach(hs => {
  hs.addEventListener('click', e => {
    e.stopPropagation();
    const popId = hs.dataset.popup;
    // close all others first
    document.querySelectorAll('.hs-popup').forEach(p => {
      if (p.id !== popId) { p.classList.remove('visible'); }
    });
    document.querySelectorAll('.hotspot').forEach(h => {
      if (h !== hs) h.classList.remove('active');
    });
    const pop = document.getElementById(popId);
    if (!pop) return;
    // position popup
    const wrap = hs.closest('.diagram-img-area');
    const wRect = wrap.getBoundingClientRect();
    const hRect = hs.getBoundingClientRect();
    const relX = hRect.left - wRect.left + hRect.width/2;
    const relY = hRect.top  - wRect.top  + hRect.height/2;
    // place above or below
    pop.style.left = Math.min(Math.max(relX - 140, 4), wRect.width - 290) + 'px';
    if (relY > wRect.height * 0.55) {
      pop.style.top = 'auto';
      pop.style.bottom = (wRect.height - relY + 12) + 'px';
    } else {
      pop.style.bottom = 'auto';
      pop.style.top = (relY + 18) + 'px';
    }
    const isOpen = pop.classList.contains('visible');
    pop.classList.toggle('visible', !isOpen);
    hs.classList.toggle('active', !isOpen);
  });
});

document.addEventListener('click', () => {
  document.querySelectorAll('.hs-popup').forEach(p => p.classList.remove('visible'));
  document.querySelectorAll('.hotspot').forEach(h => h.classList.remove('active'));
});

function closePopup(id) {
  document.getElementById(id)?.classList.remove('visible');
  document.querySelectorAll('.hotspot').forEach(h => h.classList.remove('active'));
}

// ── ACCORDIONS ──
function toggleAcc(btn) {
  const body = btn.nextElementSibling;
  const isOpen = btn.classList.contains('open');
  // close siblings
  btn.closest('.info-panel')?.querySelectorAll('.accordion-btn').forEach(b => {
    b.classList.remove('open');
    b.nextElementSibling.style.maxHeight = '0';
  });
  if (!isOpen) {
    btn.classList.add('open');
    body.style.maxHeight = body.scrollHeight + 'px';
  }
}

// ── PATHWAY STRIP ──
const pwData = {
  'audi-pathway': [
    {h:'Cochlear Nuclei (Medulla)', p:'First CNS synapse. The cochlear nerve synapses here in the dorsal and ventral cochlear nuclei. Encodes frequency, intensity, and timing. Projections both <strong>cross (decussate)</strong> via the trapezoid body and ascend ipsilaterally — giving rise to bilateral central auditory processing.'},
    {h:'Superior Olivary Complex (Pons)', p:'First site of <strong>binaural integration</strong> in the ascending pathway. Critical for sound localization using interaural time differences (ITD) and interaural level differences (ILD). The olivocochlear bundle sends efferent projections back to cochlear outer hair cells, modulating their sensitivity.'},
    {h:'Inferior Colliculus (Midbrain)', p:'A major auditory integration center. Processes complex temporal patterns, important for speech rhythm and phoneme boundaries. All ascending auditory fibers synapse here. Also mediates the <strong>auditory startle reflex</strong>. Input from both ears converges here.'},
    {h:'Medial Geniculate Body / Thalamus', p:'The auditory relay nucleus of the thalamus. Receives input from the inferior colliculus and projects to the primary auditory cortex (Heschl\'s gyrus). Maintains tonotopic organization. The thalamus also gates sensory information — controlling what reaches conscious awareness.'},
    {h:'Primary Auditory Cortex — Heschl\'s Gyrus (A1)', p:'Located on the transverse temporal gyri, <strong>Brodmann areas 41 &amp; 42</strong>, in the superior temporal plane. Tonotopically organized. Processes basic acoustic features: frequency, intensity, duration, and timing. Receives primarily contralateral input. The planum temporale (posterior to A1) is larger in the left hemisphere — an anatomical asymmetry linked to language dominance.'},
    {h:"Wernicke's Area — Language Comprehension", p:'<strong>Posterior superior temporal gyrus, Brodmann area 22</strong>, typically left hemisphere. This is where the acoustic features processed in A1 are decoded as <em>language</em>. Wernicke\'s area recognizes "Do you like cheese?" as a yes/no question about cheese preference — triggering the need for a spoken response. It connects to Broca\'s area via the arcuate fasciculus.'},
  ]
};

function setPW(id, idx, node) {
  const strip = document.getElementById(id);
  strip.querySelectorAll('.pw-node').forEach(n => n.classList.remove('active'));
  node.classList.add('active');
  const detail = document.getElementById(id + '-detail');
  const data = pwData[id][idx];
  detail.innerHTML = `<h4>${data.h}</h4><p>${data.p}</p>`;
}

// ── SCROLL ACTIVE NAV ──
const secMap = {
  'auditory':'b-audi','neuro-receive':'b-neuro-r','neuro-formulate':'b-neuro-f',
  'respiratory':'b-resp','phonatory':'b-phon','resonatory':'b-reso','articulatory':'b-arti'
};
const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
      const cls = secMap[entry.target.id];
      if (cls) document.querySelector('.' + cls)?.classList.add('active');
    }
  });
}, { threshold: 0.3, rootMargin: '-60px 0px -40% 0px' });

Object.keys(secMap).forEach(id => {
  const el = document.getElementById(id);
  if (el) observer.observe(el);
});

// ── MODAL ──
function closeModal() {
  document.getElementById('modal-overlay').classList.remove('open');
}
</script>
